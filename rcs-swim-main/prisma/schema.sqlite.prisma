// Prisma schema for RCS Club - SQLite (Development)
// Matches Excel file: منظومة_اشتراكات_RCS_v2.xlsx (ورقة "بيانات")
// For production (Vercel + Supabase), use schema.prisma.postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// نموذج المنخرط — يطابق ورقة "بيانات" في ملف Excel
// الأعمدة الـ 19 في ملف Excel:
// A: رقم الملف | B: اللقب | C: الاسم | D: تاريخ الميلاد | E: الجنس
// F: العمر (محسوب) | G: فصيلة الدم | H: نوع الاشتراك | I: تاريخ آخر دفعة
// J: تاريخ انتهاء الاشتراك (محسوب) | K: حالة الدفع | L: رسوم الاشتراك (محسوب)
// M: مصاريف التأمين (محسوب) | N: حقوق المركب (محسوب) | O: المبلغ الإجمالي (محسوب)
// P: حالة التجديد (محسوب) | Q: أيام السباحة | R: التوقيت | S: عدد أشهر الاشتراك (محسوب)
model Subscriber {
  id              String   @id @default(cuid())
  fileNumber      String   @unique                    // A: رقم الملف (RCS 001)
  lastName        String                              // B: اللقب
  firstName       String                              // C: الاسم
  birthDate       DateTime                            // D: تاريخ الميلاد
  gender          String                              // E: الجنس (ذكر/أنثى)
  bloodType       String?                             // G: فصيلة الدم
  subscriptionType String                             // H: نوع الاشتراك (/, OPOW, DJS, FCS, RCS, POLICE)
  lastPaymentDate DateTime?                           // I: تاريخ آخر دفعة
  paymentStatus   String                              // K: حالة الدفع (مدفوع/لم يدفع/تأمين فقط/اشتراك 300)
  swimmingDays    String?                             // Q: أيام السباحة
  timeSlot        String?                             // R: التوقيت
  phone           String?                             // حقل إضافي للواتساب
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  renewals        Renewal[]
  attendances     Attendance[]
  activities      Activity[]
  payments        Payment[]
  compensations   Compensation[]

  @@index([paymentStatus])
  @@index([subscriptionType])
  @@index([gender])
}

// نموذج التجديد — يطابق ورقة "التجديد" في ملف Excel
// A: رقم الملف | B: اللقب | C: الاسم | D: نهاية الاشتراك السابق
// E: تاريخ التجديد | F: نهاية الشهر الجديد | G: مبلغ التجديد | H: حالة الدفع | I: حالة التجديد
model Renewal {
  id              String   @id @default(cuid())
  subscriberId    String
  subscriber      Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  renewalDate     DateTime                            // E: تاريخ التجديد
  expiryDate      DateTime                            // F: نهاية الشهر الجديد
  months          Int      @default(1)                // عدد الأشهر
  amount          Int                                 // G: مبلغ التجديد
  paymentStatus   String                              // H: حالة الدفع
  note            String?
  createdAt       DateTime @default(now())

  @@index([subscriberId])
}

model Attendance {
  id              String   @id @default(cuid())
  subscriberId    String
  subscriber      Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  date            DateTime
  checkInTime     DateTime
  checkOutTime    DateTime?
  method          String
  coachId         String?
  note            String?
  isCompensation  Boolean  @default(false)
  createdAt       DateTime @default(now())

  compensation    Compensation?

  @@unique([subscriberId, date])
  @@index([date])
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  passwordHash    String
  role            String   @default("lifeguard")
  phone           String?
  avatar          String?
  active          Boolean  @default(true)
  pending         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workHours       WorkHours[]
  payments        Payment[]
}

model WorkHours {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime
  startTime       DateTime
  endTime         DateTime
  status          String   @default("pending")
  note            String?
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([userId, date])
  @@index([status])
}

model Payment {
  id              String   @id @default(cuid())
  subscriberId    String?
  subscriber      Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  category        String
  amount          Int
  method          String   @default("cash")
  receiptNumber   String?
  date            DateTime @default(now())
  note            String?
  status          String   @default("paid")
  createdAt       DateTime @default(now())

  @@index([subscriberId])
  @@index([category])
  @@index([date])
  @@index([userId])
}

model Activity {
  id              String   @id @default(cuid())
  subscriberId    String?
  subscriber      Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  userId          String?
  type            String
  description     String
  metadata        String?
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

model Notification {
  id              String   @id @default(cuid())
  userId          String?
  type            String
  title           String
  message         String
  read            Boolean  @default(false)
  link            String?
  createdAt       DateTime @default(now())

  @@index([userId, read])
}

model Setting {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  updatedAt       DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════
// POOL CLOSURES (إغلاق المسبح للصيانة)
// ═══════════════════════════════════════════════════════════
model PoolClosure {
  id              String   @id @default(cuid())
  date            DateTime
  swimmingDays    String?
  timeSlot        String?
  reason          String
  note            String?
  createdById     String?
  createdAt       DateTime @default(now())

  compensations   Compensation[]

  @@index([date])
}

// ═══════════════════════════════════════════════════════════
// COMPENSATIONS (تعويضات المنخرطين)
// ═══════════════════════════════════════════════════════════
model Compensation {
  id                        String   @id @default(cuid())
  closureId                 String?
  closure                   PoolClosure? @relation(fields: [closureId], references: [id], onDelete: SetNull)
  subscriberId              String
  subscriber                Subscriber  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  originalDate              DateTime
  originalSwimmingDays      String?
  originalTimeSlot          String?

  status                    String   @default("pending")

  compensationDate          DateTime?
  compensationSwimmingDays  String?
  compensationTimeSlot      String?

  notifiedAt                DateTime?
  usedAt                    DateTime?
  attendanceId              String?  @unique
  attendance                Attendance? @relation(fields: [attendanceId], references: [id], onDelete: SetNull)

  note                      String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([status])
  @@index([subscriberId])
  @@index([closureId])
}
