# ═══════════════════════════════════════════════════════════
# Example .env file for RCS Swim Manager
# Copy to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════

# Neon PostgreSQL database (pooled for production)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true&connection_limit=1"

# Neon direct connection (for migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# NextAuth.js secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-key-here-at-least-32-chars"

# Optional: Vercel auto-detects these, but useful for local dev
# NEXTAUTH_URL="http://localhost:3000"
