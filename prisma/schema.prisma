// Prisma schema for RCS Club — Multi-Tenant Platform
// النادي الهاوي متعدد الرياضات — الرائد سعيدة — فرع السباحة
// Multi-Tenant: each club is an isolated tenant

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════════════════
// MULTI-TENANT MODELS
// ═══════════════════════════════════════════════════════════

// Club (النادي) — each club is a tenant
model Club {
  id              String   @id @default(cuid())
  name            String                            // اسم النادي
  city            String                            // المدينة
  country         String   @default("الجزائر")       // الدولة
  managerName     String                            // اسم المسؤول
  phone           String                            // رقم الهاتف
  email           String   @unique                  // البريد الإلكتروني
  status          String   @default("pending")      // pending/active/expired/disabled/suspended
  syncApiKey      String?  @unique                   // مفتاح المزامنة بين الفرع الأوفلاين والسحابة
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // ─── Trial & Subscription state ───
  trialStartedAt  DateTime?                         // بداية التجربة المجانية (عند الموافقة)
  trialEndDate    DateTime?                         // نهاية التجربة (7-15 يوم من الموافقة)
  graceEndDate    DateTime?                         // نهاية فترة السماح (أسبوع بعد انتهاء الاشتراك)
  hardwareFingerprint String?                       // بصمة الجهاز (لمنع النسخ لجهاز آخر)

  // Relations
  users           User[]
  subscribers     Subscriber[]
  renewals        Renewal[]
  attendances     Attendance[]
  workHours       WorkHours[]
  payments        Payment[]
  activities      Activity[]
  notifications   Notification[]
  poolClosures    PoolClosure[]
  compensations   Compensation[]
  syncOutbox      SyncOutbox[]
  waitlists           Waitlist[]
  subscriberContracts SubscriberContract[]
  settings        Setting[]
  cashierPins     CashierPin[]
  subscriptionTypes SubscriptionType[]
  swimmingDays     SwimmingDay[]
  swimmingTimeSlots SwimmingTimeSlot[]
  subscriptions   ClubSubscription[]
  requests        ClubRequest[]
  employees       Employee[]
  contracts       EmploymentContract[]
  contractTemplates ContractTemplate[]
  activationCodes ActivationCode[]                  // الأكواد المُفعَّلة لهذا النادي
}

// Club subscription (اشتراك النادي)
model ClubSubscription {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  type            String                            // monthly/yearly
  startDate       DateTime
  endDate         DateTime
  status          String   @default("active")       // active/expired/suspended/cancelled
  lastRenewalDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  history         SubscriptionHistory[]

  @@index([clubId])
  @@index([status])
}

// Subscription history (سجل تجديدات الاشتراك)
model SubscriptionHistory {
  id              String   @id @default(cuid())
  subscriptionId  String
  subscription    ClubSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  action          String                            // created/renewed/changed/extended/ended/suspended/reactivated
  oldType         String?
  newType         String?
  oldEndDate      DateTime?
  newEndDate      DateTime?
  note            String?
  createdAt       DateTime @default(now())

  @@index([subscriptionId])
}

// ═══════════════════════════════════════════════════════════
// ACTIVATION CODES SYSTEM (نظام أكواد التفعيل المشفّرة)
// ═══════════════════════════════════════════════════════════
// أكواد موقّعة رقمياً (HMAC-SHA256) — تعمل أوفلاين 100%
// التحقق يتم محلياً بالرياضيات، التسجيل في DB يمنع إعادة الاستخدام

// Batch (دفعة توليد) — لتتبع من/متى ولّد الأكواد
model CodeBatch {
  id              String   @id @default(cuid())
  batchNo         Int       @unique                 // رقم الدفعة التسلسلي
  name            String?                           // اسم وصفي (اختياري)
  plan            String                            // monthly/quarterly/halfyear/yearly/twoyear
  count           Int                               // عدد الأكواد في الدفعة
  generatedById   String?                           // SuperAdmin ID
  generatedBy     User?     @relation(fields: [generatedById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  notes           String?

  codes           ActivationCode[]

  @@index([plan])
}

// Activation Code (كود التفعيل)
model ActivationCode {
  id              String   @id @default(cuid())
  code            String   @unique                 // الكود الكامل: AQCR-XXXX-XXXX-XXXX
  codeHash        String   @unique                 // SHA256(code) للبحث السريع بدون كشف الكود
  batchId         String
  batch           CodeBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  plan            String                            // monthly/quarterly/halfyear/yearly/twoyear
  durationDays    Int                               // عدد الأيام (30/90/180/365/730)
  status          String   @default("unused")       // unused/used/revoked/expired
  // ─── عند التفعيل ───
  clubId          String?
  club            Club?     @relation(fields: [clubId], references: [id], onDelete: SetNull)
  activatedAt     DateTime?
  activatedById   String?                           // المستخدم الذي فعّل
  hardwareFingerprint String?                       // بصمة الجهاز عند التفعيل (منع النسخ)
  expiresAt       DateTime?                         // تاريخ انتهاء الاشتراك الناتج
  // ─── التدقيق ───
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  revokedAt       DateTime?
  revokedReason   String?

  @@index([batchId])
  @@index([status])
  @@index([clubId])
  @@index([plan])
}

// Club registration request (طلب تسجيل نادي جديد)
model ClubRequest {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  status          String   @default("pending")      // pending/approved/rejected
  reviewedBy      String?                           // SuperAdmin user ID
  reviewedAt      DateTime?
  note            String?
  createdAt       DateTime @default(now())

  @@index([clubId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════
// EXISTING MODELS (updated with clubId)
// ═══════════════════════════════════════════════════════════

model Subscriber {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  fileNumber      String                                // RCS 001
  lastName        String
  firstName       String
  birthDate       DateTime
  gender          String                                // ذكر/أنثى
  bloodType       String?
  subscriptionType String
  lastPaymentDate DateTime?
  paymentStatus   String
  swimmingDays    String?
  timeSlot        String?
  phone           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?                             // حذف ناعم — يبقى محفوظاً للمزامنة

  renewals        Renewal[]
  attendances     Attendance[]
  activities      Activity[]
  payments        Payment[]
  compensations   Compensation[]
  contracts       SubscriberContract[]

  @@unique([clubId, fileNumber])
  @@index([clubId])
  @@index([clubId, paymentStatus])
  @@index([clubId, subscriptionType])
  @@index([clubId, gender])
}

model Renewal {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  subscriberId    String
  subscriber      Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  renewalDate     DateTime
  expiryDate      DateTime
  months          Int      @default(1)
  amount          Int
  paymentStatus   String
  note            String?
  createdAt       DateTime @default(now())

  @@index([clubId])
  @@index([clubId, subscriberId])
}

model Attendance {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  subscriberId    String
  subscriber      Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  date            DateTime
  checkInTime     DateTime
  checkOutTime    DateTime?
  method          String
  coachId         String?
  note            String?
  isCompensation  Boolean  @default(false)          // هل هذا حضور لحصة تعويضية؟
  createdAt       DateTime @default(now())

  compensation    Compensation?

  @@unique([clubId, subscriberId, date])
  @@index([clubId, date])
}

model User {
  id              String   @id @default(cuid())
  clubId          String?
  club            Club?    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  email           String   @unique
  name            String
  passwordHash    String
  role            String   @default("lifeguard")    // superadmin/admin/assistant/lifeguard/observer
  phone           String?
  avatar          String?
  active          Boolean  @default(true)
  pending         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workHours       WorkHours[]
  payments        Payment[]
  sessions        Session[]
  employees       Employee[]
  codeBatches     CodeBatch[]                       // الدفعات التي ولّدها هذا المستخدم
}

model WorkHours {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime
  startTime       DateTime
  endTime         DateTime
  status          String   @default("pending")
  note            String?
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([clubId, userId, date])
  @@index([clubId, status])
}

model Payment {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  subscriberId    String?
  subscriber      Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  category        String
  amount          Int
  method          String   @default("cash")
  receiptNumber   String?
  date            DateTime @default(now())
  note            String?
  status          String   @default("paid")
  createdAt       DateTime @default(now())

  @@index([clubId])
  @@index([clubId, subscriberId])
  @@index([clubId, category])
  @@index([clubId, date])
}

model Activity {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  subscriberId    String?
  subscriber      Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  userId          String?
  type            String
  description     String
  metadata        String?
  createdAt       DateTime @default(now())

  @@index([clubId, createdAt])
}

model Notification {
  id              String   @id @default(cuid())
  clubId          String?
  club            Club?    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  userId          String?
  type            String
  title           String
  message         String
  read            Boolean  @default(false)
  link            String?
  createdAt       DateTime @default(now())

  @@index([clubId, userId, read])
}

model Setting {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  key             String
  value           String
  updatedAt       DateTime @updatedAt

  @@unique([clubId, key])
  @@index([clubId])
}

model Session {
  id              String   @id
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data            String
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model CashierPin {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  pin             String   @unique
  label           String   @default("كاشير")
  role            String   @default("assistant")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clubId])
  @@index([clubId, active])
  @@index([active])
}

// ═══════════════════════════════════════════════════════════
// SUBSCRIPTION TYPES (أنواع الاشتراك) — per club
// ═══════════════════════════════════════════════════════════
model SubscriptionType {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name            String
  code            String
  color           String   @default("#0d9488")
  description     String?

  // الرسوم
  subscriptionFee Int      @default(0)
  insuranceFee    Int      @default(500)
  compoundRights  Int      @default(1000)
  durationDays    Int      @default(30)

  // الخيارات (Checkboxes) — خصائص ديناميكية
  givesMembershipNumber Boolean @default(true)   // يمنح رقم عضوية (رقم ملف)
  requiresInsurance     Boolean @default(true)   // يخضع للتأمين
  requiresCompoundFee   Boolean @default(true)   // يخضع لحقوق المركب
  renewableMonthly      Boolean @default(true)   // قابل للتجديد الشهري
  freeSubscription      Boolean @default(false)  // نوع مجاني (كل الرسوم = 0)

  // نظام الترقيم — يحدد مجموعة العداد (RCS / M / X / إلخ)
  numberingGroup  String   @default("RCS")  // مجموعة الترقيم: RCS, M, X, إلخ

  // قديم (للتوافق)
  requiresInsuranceLegacy Boolean @default(true)
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clubId, code])
  @@index([clubId])
}

// ═══════════════════════════════════════════════════════════
// SWIMMING DAYS (أيام السباحة) — per club
// ═══════════════════════════════════════════════════════════
model SwimmingDay {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name            String
  shortName       String
  color           String   @default("#0d9488")
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clubId, name])
  @@index([clubId])
}

// ═══════════════════════════════════════════════════════════
// SWIMMING TIME SLOTS (توقيتات السباحة) — per club
// ═══════════════════════════════════════════════════════════
model SwimmingTimeSlot {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name            String
  startTime       String
  endTime         String
  maxCapacity     Int      @default(30)
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clubId, name])
  @@index([clubId])
}

// ═══════════════════════════════════════════════════════════
// EMPLOYEES (العمال) — per club, linked to User
// ═══════════════════════════════════════════════════════════
model Employee {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  userId          String?  // optional link to User (for login accounts)
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Personal data (auto-filled from User if linked)
  firstName       String
  lastName        String
  birthDate       DateTime?
  birthPlace      String?
  address         String?
  phone           String?
  nationalId      String?

  // Job data
  position        String   // guard/coach/admin/maintenance/cleaner/seasonal/other
  hireDate        DateTime @default(now())

  // Financial
  hourRate        Int      @default(200)

  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contracts       EmploymentContract[]

  @@unique([clubId, nationalId])
  @@index([clubId])
  @@index([clubId, position])
}

// ═══════════════════════════════════════════════════════════
// EMPLOYMENT CONTRACTS (عقود العمل) — per club
// ═══════════════════════════════════════════════════════════
model EmploymentContract {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  templateId      String?
  template        ContractTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  contractNumber  String   // unique per club: e.g. CTR-2025-001
  position        String
  startDate       DateTime
  endDate         DateTime?
  hourRate        Int      @default(200)
  monthlySalary   Int?
  workSchedule    String?  // e.g. "40 ساعة/أسبوع"

  // Snapshot of the rendered content (after variable substitution)
  content         String   // HTML content with substituted variables

  // Metadata
  status          String   @default("active") // active/expired/terminated/renewed
  version         Int      @default(1)
  notes           String?

  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([clubId, contractNumber])
  @@index([clubId, employeeId])
  @@index([clubId, status])
}

// ═══════════════════════════════════════════════════════════
// CONTRACT TEMPLATES (قوالب العقود) — per club
// ═══════════════════════════════════════════════════════════
model ContractTemplate {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  name            String   // "عقد حارس السباحة", "عقد مدرب", etc.
  code            String   // guard/coach/admin/maintenance/cleaner/seasonal/other
  description     String?
  content         String   // HTML template with {{variables}}
  defaultDuration Int      @default(365) // days
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contracts       EmploymentContract[]

  @@unique([clubId, code])
  @@index([clubId])
}

// ═══════════════════════════════════════════════════════════
// POOL CLOSURES (إغلاق المسبح للصيانة) — per club
// ═══════════════════════════════════════════════════════════
model PoolClosure {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  date            DateTime                        // تاريخ الإغلاق
  swimmingDays    String?                          // مجموعة الأيام المتأثرة (مثال: "الأحد والأربعاء") — null = كل المجموعات
  timeSlot        String?                          // التوقيت المتأثر (مثال: "09:00-10:00") — null = كل التوقيتات
  reason          String                           // سبب الإغلاق (صيانة، تنظيف عميق، عطل تقني...)
  note            String?

  createdById     String?
  createdAt       DateTime @default(now())

  compensations   Compensation[]

  @@index([clubId, date])
}

// ═══════════════════════════════════════════════════════════
// COMPENSATIONS (تعويضات المنخرطين) — per club
// ═══════════════════════════════════════════════════════════
model Compensation {
  id                    String   @id @default(cuid())
  clubId                String
  club                  Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  closureId             String?
  closure               PoolClosure? @relation(fields: [closureId], references: [id], onDelete: SetNull)
  subscriberId          String
  subscriber            Subscriber  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  originalDate          DateTime                   // الحصة الأصلية المفقودة
  originalSwimmingDays  String?
  originalTimeSlot      String?

  status                String   @default("pending")  // pending / scheduled / used / expired / cancelled

  compensationDate      DateTime?                  // تاريخ الحصة التعويضية (بعد تحديدها)
  compensationSwimmingDays String?
  compensationTimeSlot  String?

  notifiedAt            DateTime?                  // متى تم إشعار المنخرط
  usedAt                DateTime?                  // متى حضر الحصة التعويضية فعلياً
  attendanceId          String?  @unique            // ربط بسجل الحضور عند الاستخدام
  attendance             Attendance? @relation(fields: [attendanceId], references: [id], onDelete: SetNull)

  note                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([clubId, status])
  @@index([clubId, subscriberId])
  @@index([closureId])
}

// ═══════════════════════════════════════════════════════════
// SYNC ENGINE (المزامنة بين الفرع الأوفلاين والسحابة)
// ═══════════════════════════════════════════════════════════
model SyncOutbox {
  id          String   @id @default(cuid())
  clubId      String
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  modelName   String   // "subscriber" | "payment" | "renewal" | "attendance" | "compensation" ...
  recordId    String
  operation   String   // "create" | "update" | "delete"
  payload     String   // JSON.stringify() للسجل كامل وقت الحفظ

  createdAt   DateTime @default(now())
  synced      Boolean  @default(false)
  syncedAt    DateTime?

  @@index([clubId, synced])
}

model SyncMeta {
  id            String   @id @default("singleton")
  lastPullAt    DateTime?
  deviceId      String   @default(cuid())
  updatedAt     DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════
// WAITLIST (قائمة الانتظار الذكية)
// ═══════════════════════════════════════════════════════════
model Waitlist {
  id                String   @id @default(cuid())
  clubId            String
  club              Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  firstName         String
  lastName          String
  phone             String?
  desiredSwimmingDays String
  desiredTimeSlot   String

  status            String   @default("waiting")   // waiting | notified | converted | cancelled
  note              String?

  convertedSubscriberId String?                      // إذا تحوّل لمشترك فعلي

  notifiedAt        DateTime?
  convertedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([clubId, status])
  @@index([clubId, desiredSwimmingDays, desiredTimeSlot])
}

// ═══════════════════════════════════════════════════════════
// SUBSCRIBER CONTRACTS (العقد الإلكتروني بتوقيع رقمي)
// ═══════════════════════════════════════════════════════════
model SubscriberContract {
  id              String   @id @default(cuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  subscriberId    String
  subscriber      Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  contractText    String     // نص الشروط والأحكام وقت التوقيع (لقطة، حتى لو تغيّر النص لاحقاً)
  signerName      String     // اسم الموقّع (المشترك أو ولي أمره)
  signatureImage  String     // Base64 PNG لصورة التوقيع المرسومة
  signedAt        DateTime   @default(now())
  ipAddress       String?

  status          String   @default("signed")  // signed | revoked
  createdAt       DateTime @default(now())

  @@index([clubId, subscriberId])
}

// ═══════════════════════════════════════════════════════════
// AUDIT LOG (سجل التدقيق — لتتبع الأفعال الحساسة)
// ═══════════════════════════════════════════════════════════
model AuditLog {
  id              String   @id @default(cuid())
  clubId          String?
  userId          String?                           // المستخدم الذي قام بالفعل
  action          String                            // login|logout|create|update|delete|activate|revoke
  entityType      String                            // subscriber|user|club|code|payment|...
  entityId        String?                           // معرّف الكيان المتأثر
  description     String                            // وصف بالعربية
  ipAddress       String?
  userAgent       String?
  metadata        String?                           // JSON string لتفاصيل إضافية
  createdAt       DateTime @default(now())

  @@index([clubId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}
